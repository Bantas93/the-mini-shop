        <div class="container">
            <form action="/user/<%= Profiled.id %>/edit" method="POST">

                <div class="mb-3">
                    <label class="form-label">
                        Username
                    </label>

                    <input type="text" name="username" class="form-control" value="<%= Profiled.User.username %>" />
                </div>

                <div class="mb-3">
                    <label class="form-label">
                        Email
                    </label>

                    <input type="email" name="email" class="form-control" value="<%= Profiled.User.email %>" />
                </div>

                <!-- <div class="mb-3">
                <label class="form-label">
                    Password
                </label>

                <input type="password" name="password" class="form-control" placeholder="Enter password" />
            </div> -->
                <div class="mb-3">
                    <label class="form-label">
                        Address
                    </label>

                    <input type="text" name="address" class="form-control" value="<%= Profiled.address %>" />
                </div>

                <div class="mb-3">
                    <label class="form-label">
                        Phone Number
                    </label>

                    <input type="text" name="phoneNumber" class="form-control" value="<%= Profiled.phoneNumber %>" />
                </div>


                <div class="mb-4">
                    <label class="form-label">
                        Role
                    </label>

                    <select name="role" class="form-select">
                        <option value="" disabled>Choose role</option>
                        <option value="admin" <%=Profiled.User.role==="admin" ?"selected":"" %>>Admin</option>
                        <option value="customer" <%=Profiled.User.role==="customer" ?"selected":"" %>>Customer</option>
                    </select>
                </div>

                <button type="submit" class="btn btn-primary w-100">
                    Submit
                </button>

            </form>
        </div>
</body>

</html>