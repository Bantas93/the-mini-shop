<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
        crossorigin="anonymous"></script>
    <title>Products</title>
</head>

<body>

    <%- include('./partials/navbar.ejs') %>

        <div class="container py-5">
            <h2 class="fw-bold mb-4">
                Cart
            </h2>

            <% if (productName) { %>
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <strong>
                        <%= productName %>
                    </strong> Success deleted!
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
                <% } %>

                    <div class="row g-4">
                        <% if(transaction && transaction.TransactionItems.length) { %>
                            <% transaction.TransactionItems.forEach(el=> { %>

                                <div class="col-md-4 col-lg-3">

                                    <div class="card shadow-sm h-100">

                                        <div class="card-body d-flex flex-column">

                                            <h5 class="card-title fw-bold">
                                                <%= el.Product.name %>
                                            </h5>

                                            <p class="card-text mb-2">
                                                Price :
                                                <span class="fw-semibold">
                                                    <%= el.Product.formatPrice %>
                                                </span>
                                            </p>

                                            <p class="card-text mb-4">
                                                Qty :
                                                <span class="badge bg-success">
                                                    <%= el.qty %>
                                                </span>
                                            </p>

                                            <form method="post" action="/cart/remove/<%= el.id %>">
                                                <button class="btn btn-danger mt-auto">
                                                    Delete
                                                </button>
                                            </form>

                                        </div>

                                    </div>

                                </div>

                                <% }) %>

                                    <% } else { %>
                                        <h6 class="text-center">Cart Empty</h6>

                                        <% } %>

                    </div>
                    <br>

                    <% if(transaction && transaction.TransactionItems.length) { %>
                        <h4>
                            Total :
                            Rp <%= Number(transaction.totalPrice).toLocaleString("id-ID") %>
                        </h4>
                        <form method="post" action="/checkout">
                            <button class="btn btn-success">
                                Checkout
                            </button>
                        </form>
                        <% } %>
        </div>

</body>

</html>